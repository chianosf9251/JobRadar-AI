{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "strict": true,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["src", "scripts"],
  "exclude": ["node_modules"]
}
